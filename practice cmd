docker pull ubuntu              # Download image from Docker Hub
docker images                   # List all images
docker rmi ubuntu               # Remove image
docker build -t myapp .         # Build image from Dockerfile
docker run ubuntu               # Run container
docker run -it ubuntu bash      # Interactive mode
docker run -d nginx             # Run in background (detached mode)
docker ps                       # Show running containers
docker ps -a                    # Show all containers
docker stop <container_id>      # Stop container
docker start <container_id>     # Start container
docker restart <container_id>   # Restart container
docker rm <container_id>        # Remove container
